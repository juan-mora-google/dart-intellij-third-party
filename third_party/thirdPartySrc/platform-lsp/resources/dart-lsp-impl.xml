<idea-plugin>

  <extensions defaultExtensionNs="com.intellij">
    <registryKey defaultValue="100" description="LSP server connect timeout" key="dart.lsp.server.connect.timeout"/>
    <notificationGroup id="Dart: LSP window/showMessage"
                       displayType="BALLOON"
                       bundle="messages.DartLspBundle"
                       key="notification.group.lsp.message"/>
    <notificationGroup id="Dart: LSP window/logMessage: errors, warnings"
                       displayType="NONE"
                       bundle="messages.DartLspBundle"
                       key="notification.group.lsp.log.errors.warnings"/>
    <notificationGroup id="Dart: LSP window/logMessage: info, log; $/logTrace"
                       displayType="NONE" isLogByDefault="false"
                       bundle="messages.DartLspBundle"
                       key="notification.group.lsp.log.info.trace"/>

    <projectService serviceInterface="com.intellij.platform.dartlsp.api.LspServerManager"
                    serviceImplementation="com.intellij.platform.dartlsp.impl.LspServerManagerImpl"/>

    <editorFactoryDocumentListener
                                   implementation="com.intellij.platform.dartlsp.impl.platformListeners.LspDocumentListener"/>
    <vfs.asyncListener
                       implementation="com.intellij.platform.dartlsp.impl.platformListeners.LspFileListener"/>

    <highlightingPassFactory implementation="com.intellij.platform.dartlsp.impl.features.highlighting.LspHighlightingPassFactory"/>
    <problemFileHighlightFilter implementation="com.intellij.platform.dartlsp.impl.features.highlighting.LspProblemFileHighlightFilter"/>
    <enterHandlerDelegate order="last"
                          implementation="com.intellij.platform.dartlsp.impl.features.formatter.LspOnTypeFormattingEnterHandler"/>
    <editorTypedHandler order="last"
                        implementationClass="com.intellij.platform.dartlsp.impl.features.formatter.LspTypedActionHandler"/>
    <typedHandler order="last"
                  implementation="com.intellij.platform.dartlsp.impl.features.completion.LspAutoPopupTypedHandler"/>
    <typedHandler order="last, before LspAutoPopupTypedHandler"
                  implementation="com.intellij.platform.dartlsp.impl.features.parameterInfo.LspParameterInfoTypedHandler"/>
    <completion.contributor
                            language="any"
                            order="last, before wordCompletion, before TextMateCompletionContributor"
                            implementationClass="com.intellij.platform.dartlsp.impl.features.completion.LspCompletionContributor"/>
    <weigher
             key="completion"
             order="after priority, before prefix"
             implementationClass="com.intellij.platform.dartlsp.impl.features.completion.LspCompletionWeigher"/>
    <codeInsight.codeVisionProvider implementation="com.intellij.platform.dartlsp.impl.features.codeLens.LspCodeVisionProvider"/>
    <config.codeVisionGroupSettingProvider implementation="com.intellij.platform.dartlsp.impl.features.codeLens.LspCodeVisionGroupSettingProvider"/>
    <codeInsight.inlayProviderFactory implementation="com.intellij.platform.dartlsp.impl.features.inlayHint.LspInlayHintsProviderFactory"/>
    <codeInsight.parameterInfo language=""
                               implementationClass="com.intellij.platform.dartlsp.impl.features.parameterInfo.LspParameterInfoHandler"/>
    <psi.implicitReferenceProvider
                                   implementation="com.intellij.platform.dartlsp.impl.features.navigation.LspImplicitReferenceProvider"/>
    <psi.implicitReferenceProvider
                                   implementation="com.intellij.platform.dartlsp.impl.features.navigation.LspDocumentLinkReferenceProvider"/>
    <lang.symbolTypeProvider implementation="com.intellij.platform.dartlsp.impl.features.navigation.LspSymbolTypeProvider"/>
    <uiDataRule implementation="com.intellij.platform.dartlsp.impl.features.usages.LspSearchTargetsRule"/>
    <searcher forClass="com.intellij.find.usages.api.UsageSearchParameters"
              implementationClass="com.intellij.platform.dartlsp.impl.features.usages.LspUsageSearcher"/>
    <platform.backend.documentation.targetProvider
                                                   implementation="com.intellij.platform.dartlsp.impl.features.documentation.LspDocumentationTargetProvider"/>
    <formattingService implementation="com.intellij.platform.dartlsp.impl.features.formatter.LspFormattingService"/>
    <lang.importOptimizer language="Dart" implementationClass="com.intellij.platform.dartlsp.impl.features.formatter.LspImportOptimizer" order="last"/>
    <lang.foldingBuilder language="" implementationClass="com.intellij.platform.dartlsp.impl.features.folding.LspFoldingBuilder"/>
    <gotoSymbolContributor implementation="com.intellij.platform.dartlsp.impl.features.workspaceSymbol.LspGoToSymbolContributor"/>
    <gotoClassContributor implementation="com.intellij.platform.dartlsp.impl.features.workspaceSymbol.LspGoToClassContributor"/>
    <searchEverywhereResultsEqualityProvider
      implementation="com.intellij.platform.dartlsp.impl.features.workspaceSymbol.LspWorkspaceSymbolEqualityProvider"/>
    <fileBreadcrumbsCollector implementation="com.intellij.platform.dartlsp.impl.features.documentSymbol.LspFileBreadcrumbsCollector"
                              order="last, after PsiFileBreadcrumbsCollector"/>
    <platform.lang.lsWidget.itemsProvider
                                          implementation="com.intellij.platform.dartlsp.impl.lsWidget.LspWidgetItemsProvider"/>
    <applicationService serviceInterface="com.intellij.platform.dartlsp.api.lsWidget.LspWidgetInternalService"
                        serviceImplementation="com.intellij.platform.dartlsp.impl.lsWidget.LspWidgetInternalServiceImpl"/>
    <applicationService serviceInterface="com.intellij.platform.dartlsp.util.Lsp4jService"
                        serviceImplementation="com.intellij.platform.dartlsp.impl.util.Lsp4jServiceImpl"/>
    <highlightUsagesHandlerFactory implementation="com.intellij.platform.dartlsp.impl.features.highlighting.LspHighlightUsagesHandlerFactory"
                                   order="last"/>
    <registryKey key="lsp.communication.standard.log.file" defaultValue="false"
                 description="Write communication logs between the IDE and external language services to idea.log file (effective only if DEBUG-level logging is enabled for the 'com.intellij.platform.dartlsp' category)."/>

    <callHierarchyProvider language=""
                           implementationClass="com.intellij.platform.dartlsp.impl.features.hierarchy.call.LspCallHierarchyProvider"
                           order="last"/>
    <typeHierarchyProvider language=""
                           implementationClass="com.intellij.platform.dartlsp.impl.features.hierarchy.type.LspTypeHierarchyProvider"
                           order="last"/>
    <extendWordSelectionHandler
                                implementation="com.intellij.platform.dartlsp.impl.features.selectWord.LspWordSelectionHandler"
                                order="last"/>

    <renameHandler implementation="com.intellij.platform.dartlsp.impl.features.rename.LspRenameHandler" order="last"/>

    <!--@formatter:off-->
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention0</className>  <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention1</className>  <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention2</className>  <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention3</className>  <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention4</className>  <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention5</className>  <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention6</className>  <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention7</className>  <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention8</className>  <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention9</className>  <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention10</className> <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention11</className> <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention12</className> <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention13</className> <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.dartlsp.impl.features.intention.LspIntention14</className> <bundleName>messages.DartLspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>DartLspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <!--@formatter:on-->
  </extensions>

  <projectListeners>
    <listener topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"
              class="com.intellij.platform.dartlsp.impl.platformListeners.LspFileEditorManagerListener"/>
  </projectListeners>

  <applicationListeners>
    <listener topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"
              class="com.intellij.platform.dartlsp.impl.platformListeners.LspFileDocumentManagerListener"/>
    <listener topic="com.intellij.openapi.actionSystem.ex.AnActionListener"
              class="com.intellij.platform.dartlsp.impl.features.navigation.CurrentActionListener"/>
  </applicationListeners>

  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.platform.dartlsp.serverSupportProvider"
                    interface="com.intellij.platform.dartlsp.api.LspServerSupportProvider" dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.platform.dartlsp.documentAdapter"
                    interface="com.intellij.platform.dartlsp.impl.LspDocumentAdapter"
                    dynamic="true"/>
  </extensionPoints>
</idea-plugin>